+static int TRPFldArcOutlinePoints(struct STRPVOI *psVOI,
+                                  double (**ppdv)[3], size_t *pnPoints,
+                                  uint32_t ulFlag) {
+   struct STRPCUBE sOutline;
+   unsigned char *pcSeen = NULL;
+   double (*pdvPoints)[3] = NULL;
+   size_t nBoundary = 0, nPoints = 0;
+   int iRC = -1;
+
+   TRPCubeInit(&sOutline,0);
+   if(psVOI == NULL || ppdv == NULL || pnPoints == NULL) goto gDone;
+   if(TRPVOIBinOutline(&psVOI->sCube,&sOutline,psVOI->uiActiveBitMask,ulFlag)
+      & CMDERR_MASK) goto gDone;
+
+   for(int iz=0;iz<sOutline.nz;++iz)
+      for(int iy=0;iy<sOutline.ny;++iy)
+         for(int ix=0;ix<sOutline.nx;++ix)
+            nBoundary += sOutline.plData[iz][iy][ix] != 0;
+
+   const size_t nx = (size_t)sOutline.nx + 1;
+   const size_t ny = (size_t)sOutline.ny + 1;
+   const size_t nz = (size_t)sOutline.nz + 1;
+   pcSeen = calloc(nx*ny*nz,sizeof(*pcSeen));
+   pdvPoints = calloc(2*nBoundary,sizeof(*pdvPoints));
+   if(pcSeen == NULL || pdvPoints == NULL) goto gDone;
+
+   for(int iz=0;iz<sOutline.nz;++iz) {
+      for(int iy=0;iy<sOutline.ny;++iy) {
+         for(int ix=0;ix<sOutline.nx;++ix) {
+            if(!sOutline.plData[iz][iy][ix]) continue;
+            for(int kk=0;kk<2;++kk) {
+               const size_t x = (size_t)ix + kk;
+               const size_t y = (size_t)iy + kk;
+               const size_t z = (size_t)iz + kk;
+               const size_t index = (z*ny + y)*nx + x;
+               if(pcSeen[index]) continue;
+               pcSeen[index] = 1;
+               pdvPoints[nPoints][XX] = sOutline.pdx[x];
+               pdvPoints[nPoints][YY] = sOutline.pdy[y];
+               pdvPoints[nPoints][ZZ] = sOutline.pdz[z];
+               ++nPoints;
+            }
+         }
+      }
+   }
+   *ppdv = pdvPoints;
+   *pnPoints = nPoints;
+   pdvPoints = NULL;
+   iRC = 0;
+   fprintf(stderr,"<I> ARC target outline: %zu boundary voxels, %zu unique corners\n",
+           nBoundary,nPoints);
+
+gDone:;
+   free(pcSeen);
+   free(pdvPoints);
+   TRPCubeFree(&sOutline,0);
+   return iRC;
+}
